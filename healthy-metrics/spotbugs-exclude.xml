<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
  <!--
    Suppress EI_EXPOSE_REP2 for HealthEvaluator storing MetricsService reference.
    MetricsService is a thread-safe singleton shared across application components.
  -->
  <Match>
    <Class name="com.stanlemon.healthy.metrics.HealthEvaluator"/>
    <Field name="metricsService"/>
    <Bug pattern="EI_EXPOSE_REP2"/>
  </Match>
</FindBugsFilter>
