# Mark Lombok-generated methods/constructors/fields with @lombok.Generated so JaCoCo (and other
# coverage/static-analysis tools) can automatically skip synthesized code. Without this, coverage
# reports penalize classes for untested getters/setters/equals/hashCode/toString/@Value constructors
# that Lombok writes on our behalf.
#
# Stop Lombok from looking further up the directory tree for overriding configs.
config.stopBubbling = true
lombok.addLombokGeneratedAnnotation = true
